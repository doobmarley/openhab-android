<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="openHAB.Base" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="sliderStyle">@style/Widget.Material3.Slider</item>
        <item name="switchStyle">@style/Widget.Material3.CompoundButton.MaterialSwitch</item>
        <item name="materialButtonOutlinedStyle">@style/openHAB.OutlineButton</item>
        <item name="floatingActionButtonStyle">@style/Widget.Material3.FloatingActionButton.Primary</item>
    </style>

    <style name="openHAB.DayNight.Base" parent="openHAB.Base">
        <item name="android:statusBarColor">?colorPrimary</item>
        <item name="chartTheme">white</item>
        <item name="transparentChartTheme">white_transparent</item>
        <item name="valueColors">@array/valueColorsBrightBackground</item>
        <item name="chartSeriesColors">@array/chartSeriesColorsBrightBackground</item>
        <item name="skeletonBackground">#F2F2F2</item>
        <item name="skeletonShimmer">#E0E0E0</item>
    </style>

    <style name="openHAB.DayNight.orange" parent="openHAB.DayNight.Base">
        <item name="colorPrimary">#1A6FCC</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#D6E8FF</item>
        <item name="colorOnPrimaryContainer">#002E6B</item>
        <item name="colorSecondary">#2D87F0</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#D6E8FF</item>
        <item name="colorOnSecondaryContainer">#002E6B</item>
        <item name="colorError">#BA1A1A</item>
        <item name="colorErrorContainer">#FFDAD6</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="colorOnErrorContainer">#410002</item>
        <item name="android:colorBackground">@color/background_default_theme_light</item>
        <item name="colorOnBackground">@color/on_background_default_theme_light</item>
        <item name="colorSurface">#F5F7FA</item>
        <item name="colorOnSurface">#0A0F1E</item>
        <item name="colorSurfaceVariant">#D6E4F7</item>
        <item name="colorOnSurfaceVariant">#1A3A5C</item>
        <item name="colorOutline">#4A7AAF</item>
        <item name="colorOnSurfaceInverse">#E8F0FC</item>
        <item name="colorSurfaceInverse">#0D1B35</item>
        <item name="colorPrimaryInverse">#90C2FF</item>
    </style>

    <style name="openHAB.DayNight.basicui" parent="openHAB.DayNight.Base">
        <item name="colorPrimary">#1A6FCC</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#D6E8FF</item>
        <item name="colorOnPrimaryContainer">#002E6B</item>
        <item name="colorSecondary">#2D87F0</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#D6E8FF</item>
        <item name="colorOnSecondaryContainer">#002E6B</item>
        <item name="colorError">#BA1A1A</item>
        <item name="colorErrorContainer">#FFDAD6</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="colorOnErrorContainer">#410002</item>
        <item name="android:colorBackground">@color/background_basicui_theme_light</item>
        <item name="colorOnBackground">@color/on_background_basicui_theme_light</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1A2E</item>
        <item name="colorSurfaceVariant">#E0EAFA</item>
        <item name="colorOnSurfaceVariant">#1A3A5C</item>
        <item name="colorOutline">#4A7AAF</item>
        <item name="colorOnSurfaceInverse">#F0F4FF</item>
        <item name="colorSurfaceInverse">#0D1421</item>
        <item name="colorPrimaryInverse">#90C2FF</item>
    </style>

    <style name="openHAB.DayNight.Black.orange" parent="openHAB.DayNight.orange">
        <item name="chartTheme">black</item>
        <item name="transparentChartTheme">black_transparent</item>
        <item name="android:windowBackground">@color/black</item>
    </style>

    <style name="openHAB.DayNight.Black.basicui" parent="openHAB.DayNight.basicui">
        <item name="chartTheme">black</item>
        <item name="transparentChartTheme">black_transparent</item>
        <item name="android:windowBackground">@color/black</item>
    </style>

    <style name="openHAB.Launch" parent="openHAB.Base">
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="colorPrimaryDark">@android:color/background_light</item>
    </style>

    <style name="Theme.MaterialComponents.TranslucentBase">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.MaterialComponents.Translucent" parent="Theme.MaterialComponents.TranslucentBase">
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
